{
  "name": "gravity-notes",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "build:single": "tsc && vite build --mode singlefile",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc && tsc -p tsconfig.node.json",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@diplodoc/cut-extension": "^1.0.0",
    "@diplodoc/file-extension": "^0.2.1",
    "@diplodoc/tabs-extension": "^3.5.1",
    "@diplodoc/transform": "^4.43.0",
    "@gravity-ui/components": "^4.20.2",
    "@gravity-ui/icons": "^2.18.0",
    "@gravity-ui/markdown-editor": "^15.40.0",
    "@gravity-ui/uikit": "^7.41.0",
    "@tanstack/react-virtual": "^3.14.4",
    "@tauri-apps/api": "^2.11.1",
    "@tauri-apps/plugin-dialog": "^2.7.1",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "fflate": "^0.8.3",
    "highlight.js": "^11.8.0",
    "katex": "^0.16.9",
    "lowlight": "^3.0.0",
    "markdown-it": "^13.0.0",
    "prosemirror-inputrules": "^1.5.1",
    "prosemirror-model": "^1.25.9",
    "prosemirror-state": "^1.4.4",
    "prosemirror-view": "^1.41.9",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@gravity-ui/eslint-config": "^4.3.1",
    "@gravity-ui/prettier-config": "^1.1.1",
    "@tauri-apps/cli": "^2.11.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/wicg-file-system-access": "^2023.10.5",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.18.0",
    "fake-indexeddb": "^6.2.5",
    "jsdom": "^29.1.1",
    "prettier": "^3.4.2",
    "typescript": "^5.9.2",
    "vite": "^5.4.11",
    "vite-plugin-singlefile": "^2.0.0",
    "vitest": "^3.2.6"
  }
}
