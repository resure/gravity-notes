{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gravity Notes",
  "version": "0.1.0",
  "identifier": "com.gravitynotes.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Gravity Notes",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1100,
        "height": 740,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["app", "dmg"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
