{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Gravity Notes Dev",
  "identifier": "com.gravitynotes.desktop.dev",
  "app": {
    "windows": [
      {
        "title": "Gravity Notes Dev",
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "width": 1100,
        "height": 740,
        "minWidth": 680,
        "minHeight": 480,
        "resizable": true,
        "fullscreen": false,
        "dragDropEnabled": false
      }
    ]
  },
  "bundle": {
    "icon": [
      "icons-dev/32x32.png",
      "icons-dev/128x128.png",
      "icons-dev/128x128@2x.png",
      "icons-dev/icon.icns",
      "icons-dev/icon.ico"
    ]
  }
}
